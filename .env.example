# Local development environment.
# Postgres runs via `docker compose up -d` (see docker-compose.yml).
DATABASE_URL=""

# NextAuth v5. Generate a real secret with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST=""
NEXTAUTH_URL=""

# AES-256-GCM key for encrypting integration tokens at rest (32 bytes, base64).
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# Microsoft Identity Platform (Outlook / 365). Fill in to enable real OAuth.
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# Canvas LMS OAuth2 (institution-specific). Base URL is set per-user at connect time.
CANVAS_CLIENT_ID=""
CANVAS_CLIENT_SECRET=""
